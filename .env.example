# ═══════════════════════════════════════════════════════════════════
# VieNeu-TTS Configuration
# ═══════════════════════════════════════════════════════════════════

# ── VieNeu-TTS API Server ─────────────────────────────────────────
# Full URL of the VieNeu-TTS server endpoint (OpenAI-compatible).
# Default: http://localhost:23333/v1/audio/speech
# For remote/tunnel: http://bore.pub:31631/v1/audio/speech
VITE_VIENEU_API_URL=http://localhost:23333/v1/audio/speech

# ── Model ID ──────────────────────────────────────────────────────
# The VieNeu-TTS model to use for synthesis.
# Options: pnnbao-ump/VieNeu-TTS-v2, pnnbao-ump/VieNeu-TTS-0.3B
VITE_VIENEU_MODEL=pnnbao-ump/VieNeu-TTS-v2

# ── Voice Preset ──────────────────────────────────────────────────
# Voice preset name. Use "default" for the server's default voice.
# Available voices can be listed via the VieNeu SDK.
VITE_VIENEU_VOICE=default

# ── Timeout (ms) ──────────────────────────────────────────────────
# How long to wait for VieNeu server before falling back to Web Speech API.
# Default: 5000 (5 seconds) — VieNeu may need more time for synthesis.
VITE_TTS_TIMEOUT_MS=5000

# ── Firebase Configuration ────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
